# ═══════════════════════════════════════════════════════════════════════════════
# SOVEREIGN SPINE — Environment Configuration
# Copy to .env.local and fill in values. Never commit .env.local.
# ═══════════════════════════════════════════════════════════════════════════════

# ── System ────────────────────────────────────────────────────────────────────
NODE_ENV=development
SYSTEM_MODE=ISSUER

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://sovereign:sovereign@localhost:5432/sovereign_spine
REDIS_URL=redis://localhost:6379

# ── XRPL ──────────────────────────────────────────────────────────────────────
XRPL_NETWORK=testnet
XRPL_WSS_PRIMARY=wss://s.altnet.rippletest.net:51233
XRPL_WSS_FALLBACK=
XRPL_ISSUER_ADDRESS=
XRPL_TREASURY_ADDRESS=
XRPL_ISSUER_SEED=

# ── Fireblocks MPC ───────────────────────────────────────────────────────────
FIREBLOCKS_API_KEY=
FIREBLOCKS_API_SECRET=
FIREBLOCKS_VAULT_ACCOUNT_ID=
FIREBLOCKS_BASE_URL=https://sandbox-api.fireblocks.io

# ── HSM ───────────────────────────────────────────────────────────────────────
HSM_PROVIDER=SOFT_HSM
HSM_SLOT=0
HSM_PIN=
AWS_KMS_KEY_ARN=

# ── Circle (USDC) ────────────────────────────────────────────────────────────
CIRCLE_API_KEY=
CIRCLE_API_BASE=https://prd-api.circle.com

# ── Authentication ───────────────────────────────────────────────────────────
JWT_SECRET=dev-secret-replace-in-production-32chars-min
SESSION_ENCRYPTION_KEY=dev-session-key-replace-in-production-32ch

# ── Anchoring ────────────────────────────────────────────────────────────────
BITCOIN_RPC_URL=
POLYGON_RPC_URL=
IPFS_API_URL=http://localhost:5001

# ── Observability ────────────────────────────────────────────────────────────
LOG_LEVEL=debug
OTEL_EXPORTER_ENDPOINT=
SENTRY_DSN=

# ── Ports ────────────────────────────────────────────────────────────────────
API_PORT=4000
CONTROL_PLANE_PORT=3100
